# Claude Code per-machine local state (auto-generated, contains user-specific
# permissions / approved commands — never commit).
.claude/settings.local.json

# Auto-generated MCP config files (per-machine). Matches /.mcp.json in
# the repo root and .claude/.mcp.json (Claude Code's own per-project
# MCP server list, regenerated on demand). Note: .vscode/mcp.json — no
# leading dot in the filename — is intentionally tracked as the
# project-shared one.
.mcp.json

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo

# Logs / dumps
*.log
npm-debug.log*

# Node — currently no build step but harmless to pre-empt
node_modules/

# Python — used by test_polygon/ (no runtime dep on Python anywhere else)
__pycache__/
*.pyc
*.pyo

# Dev-only injection harness for live-testing MAIN-world code on cor3.gg
# without packaging the extension (see inject-server.js for the helper).
# Bundle is auto-generated; the server + the JSON escape file are local
# dev tooling only.
inject-bundle.js
inject-bundle.json
inject-server.js

# Ad-hoc reverse-engineering snapshots (wire-format dumps, debug exports).
new-protocol-dump.json
cor3-autojobs-debug-*.txt
