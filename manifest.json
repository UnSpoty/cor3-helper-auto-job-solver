{
  "manifest_version": 3,
  "name": "COR3 Helper",
  "browser_specific_settings": {
    "gecko": {
      "id": "cor3-helper@cor3helper",
      "strict_min_version": "128.0"
    }
  },
  "version": "1.3.2",
  "description": "Monitor markets, expeditions, daily ops, and get timer alerts for cor3.gg.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "popup.html"
  },
  "host_permissions": [
    "https://cor3.gg/*",
    "https://os.cor3.gg/*",
    "https://svc-corie.cor3.gg/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["errors.js", "background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://cor3.gg/*",
        "https://os.cor3.gg/*"
      ],
      "js": [
        "content-early.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://cor3.gg/*",
        "https://os.cor3.gg/*"
      ],
      "js": [
        "errors.js",
        "ws-messages.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon/favicon16.png",
    "48": "icon/favicon48.png",
    "128": "icon/favicon128.png"
  },
  "action": {
    "default_icon": "icon/favicon128.png",
    "default_popup": "popup.html",
    "default_title": "COR3 Helper"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "ws-interceptor.js",
        "decrypt-solver.js",
        "daily-hack-solver.js",
        "job-manager.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
